# ============================================================
# AI Receptionist — environment variable template
#
# Copy to `.env` (root, for the API) and `apps/dashboard/.env.local`
# (for the Next.js dashboard) and fill in real values.
#
# Marked [required] envs MUST be set or the API refuses to start
# (zod-validated in apps/api/src/config.ts). Everything else has
# a safe default for local dev.
# ============================================================

# ---- Runtime ---------------------------------------------------
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000

# ---- Database  [required] -------------------------------------
# Postgres connection string. Use a local docker-compose db for dev.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_receptionist

# ---- Redis ----------------------------------------------------
# Used by BullMQ (campaign dialer) + call-state cache.
REDIS_URL=redis://localhost:6379

# ---- JWT  [required] ------------------------------------------
# Both must be at least 32 chars. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=please-replace-me-with-a-random-32-byte-hex-string-from-crypto
JWT_REFRESH_SECRET=please-replace-me-with-a-different-32-byte-hex-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Encryption  [required] -----------------------------------
# AES-256 key. EXACTLY 64 hex chars (32 bytes). Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-me-with-exactly-64-hex-chars-32-bytes-aes-256-key-here-x

# ---- xAI / Grok Voice  [required] -----------------------------
# Primary voice provider. Get a key from https://console.x.ai/
XAI_API_KEY=

# ---- ElevenLabs (optional fallback voice) ---------------------
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ---- Provider selection ---------------------------------------
VOICE_PROVIDER=grok
TELEPHONY_PROVIDER=telnyx

# ---- Telnyx (telephony + SMS) ---------------------------------
# Free dev account at https://telnyx.com/sign-up — pay-as-you-go.
TELNYX_API_KEY=
TELNYX_APP_ID=
TELNYX_PUBLIC_KEY=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_PROFILE_ID=

# ---- RingCentral (alternative telephony) ----------------------
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_REDIRECT_URI=http://localhost:3001/api/v1/integrations/ringcentral/callback
RINGCENTRAL_WEBHOOK_VERIFICATION_TOKEN=
RINGCENTRAL_SERVER_URL=https://platform.devtest.ringcentral.com

# ---- Google Calendar (optional) -------------------------------
# Free at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/google-calendar/callback

# ---- Microsoft 365 / Outlook calendar (optional) --------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/v1/integrations/microsoft-calendar/callback

# ---- SendGrid (email notifications) ---------------------------
# Free tier: 100 emails/day at https://sendgrid.com
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_FROM_NAME=AI Receptionist

# ---- Webhook delivery worker ---------------------------------
# How often the worker drains the deliveries queue. Default 15s.
WEBHOOK_DRAIN_INTERVAL_MS=15000

# ---- OpenTelemetry (optional, off by default) ----------------
# Enable distributed tracing. No paid service required:
#   • OTEL_EXPORTER=console — prints spans to stdout (dev quick-look)
#   • OTEL_EXPORTER=otlp    — POSTs to a local Jaeger / SigNoz / OTel
#                              collector at OTEL_EXPORTER_OTLP_ENDPOINT
# Leave OTEL_ENABLED blank to run uninstrumented (production default).
OTEL_ENABLED=
OTEL_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-receptionist-api

# ============================================================
# Dashboard (Next.js) — copy these to apps/dashboard/.env.local
# ============================================================
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

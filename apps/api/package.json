{
  "name": "@ai-receptionist/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch --env-file .env src/main.ts",
    "dev:worker": "tsx watch --env-file .env src/queue/worker.ts",
    "demo": "tsx watch --env-file .env src/demo-server.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "start:migrate": "node dist/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed": "tsx --env-file .env src/db/seed.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-receptionist/shared": "workspace:*",
    "@azure/identity": "^4.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.46.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/resources": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@opentelemetry/sdk-trace-base": "^1.24.0",
    "@opentelemetry/semantic-conventions": "^1.24.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/websocket": "^10.0.0",
    "@microsoft/microsoft-graph-client": "^3.0.0",
    "resend": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.0",
    "csv-parse": "^5.5.0",
    "dayjs": "^1.11.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^4.5.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^140.0.0",
    "ioredis": "^5.3.0",
    "libphonenumber-js": "^1.11.0",
    "mammoth": "^1.8.0",
    "node-cron": "^3.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.0",
    "phone": "^3.1.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "stripe": "^17.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@ai-receptionist/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/pdf-parse": "^1.1.4",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.4.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
